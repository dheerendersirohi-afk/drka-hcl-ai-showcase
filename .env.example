VITE_USE_SUPABASE=false
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Secure server-side keys for Vercel/Netlify functions. Use these online.
SARVAM_API_KEY=your-sarvam-api-key
ACCUWEATHER_API_KEY=your-accuweather-api-key
NOAA_TOKEN=your-noaa-token
AVIATIONSTACK_API_KEY=your-aviationstack-api-key
VITE_SECURE_API_BASE=/api
VITE_DISASTER_RESPONSE_URL=https://your-public-response-ui.example.com

# Local-only fallback keys for Vite development. Do not use these for public production.
VITE_SARVAM_API_KEY=your-sarvam-api-key
VITE_ACCUWEATHER_API_KEY=your-accuweather-api-key
VITE_NOAA_TOKEN=your-noaa-token
VITE_AVIATIONSTACK_API_KEY=your-aviationstack-api-key
VITE_FLIGHT_STATUS_API_KEY=your-flight-status-api-key
VITE_RAIL_STATUS_API_KEY=your-rail-status-api-key
VITE_ROAD_TRAFFIC_API_KEY=your-road-traffic-api-key
